# ─── Ethereum ───────────────────────────────────────────────
# Private key of the deployer/master wallet
# For local Hardhat dev, Account #0 key is shown below (safe to commit as-is)
MASTER_WALLET_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# RPC endpoint for the Ethereum node
# Local Hardhat: http://127.0.0.1:8545
# Sepolia testnet: https://sepolia.infura.io/v3/YOUR_INFURA_KEY
ETH_RPC_URL=http://127.0.0.1:8545

# ─── Database ────────────────────────────────────────────────
# PostgreSQL connection string (Supabase or local)
DATABASE_URL=postgresql://user:password@host:5432/postgres

# ─── Security ────────────────────────────────────────────────
# 64-char random hex string used to sign JWTs
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRET_KEY=replace_with_a_random_64_char_hex_string

# Admin portal password
ADMIN_PASSWORD=Admin@123

# ─── Dashboard Services ──────────────────────────────────
VITE_BACKEND_URL=http://localhost:8080
VITE_ML_URL=http://localhost:8001
VITE_GRAPH_URL=http://localhost:8002
ML_SERVICE_URL=http://localhost:8001

# ─── Neo4j Graph Database ────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
